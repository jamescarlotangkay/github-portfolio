import random
random.randint(1,100)
guess=input('Guess a number between 1 and 100: ')
guess=int(guess)
number=random.randint(1,100)
while guess!=number:
    if guess<number:
        print('Too low, try again.')
    else:
        print('Too high, try again.')
    guess=input('Guess a number between 1 and 100: ')
    guess=int(guess)
print('Correct! The number was', number)
